{
  "default": "#agent-updates",
  "routes": [
    {
      "match": { "action": "approval.created" },
      "channel": "#approvals"
    },
    {
      "match": { "action": "approval.resubmitted" },
      "channel": "#approvals"
    },
    {
      "match": { "action": "budget.warning" },
      "channel": "#cost-alerts"
    },
    {
      "match": { "action": "budget.exhausted" },
      "channel": "#cost-alerts"
    }
  ]
}
